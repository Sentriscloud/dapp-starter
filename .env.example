# RPC endpoint — set to the network you're deploying against.
# Mainnet (chain 7119): https://rpc.sentrixchain.com
# Testnet (chain 7120): https://testnet-rpc.sentrixchain.com
RPC_URL=https://testnet-rpc.sentrixchain.com
CHAIN_ID=7120

# Hex private key for the deploy wallet — DO NOT COMMIT THIS.
# On testnet, fund the address from https://faucet.sentrixchain.com.
DEPLOY_PRIVATE_KEY=0x...

# Address used for `pnpm read`. Same wallet as DEPLOY_PRIVATE_KEY in normal use.
DEPLOY_ADDRESS=0x...

# Optional: paste the deployed token address after `forge script Deploy.s.sol`
# so the read script can show its balance too.
# DEMO_TOKEN=0x...
